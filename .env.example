# Hermes Google Search (optional — default uses free DuckDuckGo)
GAP_SERPER_API_KEY=

# Gemini / OpenRouter (required for --provider gemini / --run-gemini)
GAP_GEMINI_API_KEY=
GAP_OPENROUTER_API_KEY=
GAP_PROVIDER=google
# Default prospecting model (Flash: $0.30/1M input; use flash-lite for cheaper runs)
GAP_GEMINI_MODEL=gemini-2.5-flash
GAP_OPENROUTER_MODEL=google/gemini-2.5-flash

# Notion pipeline (see NOTION_PIPELINE.md)
# NOTION_API_KEY: https://www.notion.so/my-integrations → Internal Integration Secret
NOTION_API_KEY=
NOTION_DATABASE_ID=38eb2287-3e66-80e9-9c4d-d8bbedeb139f
# Display name in exported TSV/CSV (Account owner column)
NOTION_ACCOUNT_OWNER=Teodor Pavel-Hiidenlampi
# Notion user UUID for Account owner people field (optional — skip if unset)
NOTION_OWNER_USER_ID=

# Sales ops dashboard event logging (optional)
PROSPECT_DASHBOARD_URL=http://127.0.0.1:8787
